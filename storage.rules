rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper to check if user is an Admin
    function isAdmin() {
      return isAuthenticated() && 
        firestore.exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // 1. Event cover images: Authenticated read access, write access strictly restricted to Admins
    match /events/{eventId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() &&
                    request.resource.size < 5 * 1024 * 1024 && // Max 5MB file size
                    request.resource.contentType.matches('image/.*'); // Only image files allowed
    }
    
    // 2. User profile uploads: Authenticated read access, write access restricted to the profile owner
    match /users/{userId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
                    request.auth.uid == userId &&
                    request.resource.size < 2 * 1024 * 1024 && // Max 2MB file size
                    request.resource.contentType.matches('image/.*'); // Only image files allowed
    }
  }
}
